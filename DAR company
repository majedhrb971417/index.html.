<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>فليت بلس - عرض أسعار إدارة الأسطول الذكي</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: #f0f4f8;
            padding: 20px;
            direction: rtl;
            color: #1e293b;
        }

        .container {
            max-width: 1100px;
            margin: auto;
        }

        /* ===== الهيدر ===== */
        .header {
            background: linear-gradient(135deg, #0c4a6e, #0f172a);
            padding: 35px 40px;
            border-radius: 20px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: 0 10px 40px rgba(12, 74, 110, 0.35);
        }

        .header h1 {
            color: #ffffff;
            font-size: 2rem;
            font-weight: 900;
        }

        .header h1 span {
            color: #67e8f9;
        }

        .header .subtitle {
            color: #94a3b8;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .header .badge-date {
            background: rgba(255,255,255,0.1);
            padding: 8px 20px;
            border-radius: 30px;
            color: #cbd5e1;
            font-weight: 600;
            font-size: 0.85rem;
            border: 1px solid rgba(255,255,255,0.08);
        }

        /* ===== بطاقات الإحصائيات السريعة ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: #ffffff;
            padding: 18px 20px;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            border: 1px solid #e2e8f0;
            text-align: center;
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-4px);
        }

        .stat-card .number {
            font-size: 2.4rem;
            font-weight: 900;
            display: block;
        }

        .stat-card .label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #64748b;
            margin-top: 2px;
        }

        .stat-card .icon {
            font-size: 1.8rem;
            display: block;
            margin-bottom: 4px;
        }

        .stat-card.blue .number { color: #2563eb; }
        .stat-card.green .number { color: #16a34a; }
        .stat-card.orange .number { color: #ea580c; }
        .stat-card.purple .number { color: #7c3aed; }
        .stat-card.teal .number { color: #0d9488; }
        .stat-card.rose .number { color: #e11d48; }

        /* ===== المحتوى الرئيسي ===== */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        @media (max-width: 768px) {
            .content-grid {
                grid-template-columns: 1fr;
            }
        }

        .card {
            background: #ffffff;
            border-radius: 16px;
            padding: 22px 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            border: 1px solid #e2e8f0;
        }

        .card h3 {
            font-size: 1.05rem;
            font-weight: 800;
            margin-bottom: 14px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card h3 .emoji {
            font-size: 1.3rem;
        }

        /* ===== قائمة الخدمات ===== */
        .service-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px dashed #f1f5f9;
        }

        .service-item:last-child {
            border-bottom: none;
        }

        .service-item .name {
            font-weight: 700;
            font-size: 0.9rem;
        }

        .service-item .check {
            color: #16a34a;
            font-weight: 900;
            font-size: 1.1rem;
        }

        /* ===== شريط النسبة ===== */
        .rate-bar-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 6px 0;
        }

        .rate-bar-track {
            flex: 1;
            height: 10px;
            background: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
        }

        .rate-bar-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 1s ease;
        }

        .rate-bar-fill.high { background: linear-gradient(90deg, #22c55e, #16a34a); }
        .rate-bar-fill.medium { background: linear-gradient(90deg, #fbbf24, #f59e0b); }
        .rate-bar-fill.low { background: linear-gradient(90deg, #f87171, #ef4444); }
        .rate-bar-fill.full { background: linear-gradient(90deg, #60a5fa, #2563eb); }

        .rate-text {
            font-weight: 800;
            font-size: 0.85rem;
            min-width: 45px;
            text-align: left;
        }

        /* ===== جدول الأسعار ===== */
        .price-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .price-table thead {
            background: #f1f5f9;
        }

        .price-table th {
            padding: 10px 12px;
            text-align: right;
            font-weight: 800;
            color: #334155;
            font-size: 0.7rem;
            text-transform: uppercase;
        }

        .price-table td {
            padding: 9px 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        .price-table .total-row {
            background: #f8fafc;
            font-weight: 800;
            border-top: 2px solid #e2e8f0;
        }

        .price-table .total-row td {
            padding: 12px;
        }

        .tag {
            display: inline-block;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.65rem;
            font-weight: 700;
        }

        .tag.green { background: #dcfce7; color: #166534; }
        .tag.blue { background: #dbeafe; color: #1e40af; }
        .tag.orange { background: #fef3c7; color: #92400e; }
        .tag.purple { background: #ede9fe; color: #5b21b6; }
        .tag.rose { background: #fce7f3; color: #9d174d; }

        /* ===== قائمة المميزات ===== */
        .feature-list {
            list-style: none;
            padding: 0;
        }

        .feature-list li {
            padding: 7px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .feature-list li:last-child {
            border-bottom: none;
        }

        .feature-list li .icon {
            font-size: 1.1rem;
        }

        /* ===== قسم التوصيات ===== */
        .recommend-box {
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            border-radius: 16px;
            padding: 20px 24px;
            border-right: 5px solid #16a34a;
            margin-top: 20px;
        }

        .recommend-box h4 {
            color: #065f46;
            font-size: 1rem;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .recommend-box p {
            color: #065f46;
            font-size: 0.9rem;
            font-weight: 600;
            line-height: 1.7;
        }

        /* ===== الفوتر ===== */
        .footer {
            background: #0f172a;
            padding: 20px 30px;
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .footer .contact {
            color: #94a3b8;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .footer .contact strong {
            color: #ffffff;
        }

        .footer .phone {
            color: #67e8f9;
            font-size: 1.2rem;
            font-weight: 900;
        }

        /* ===== تذييل الصفحة ===== */
        .watermark {
            text-align: center;
            color: #94a3b8;
            font-size: 0.7rem;
            margin-top: 15px;
            font-weight: 600;
        }

        /* أنيميشن بسيط */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card {
            animation: fadeInUp 0.6s ease forwards;
        }

        .card:nth-child(2) { animation-delay: 0.1s; }
        .stats-grid .stat-card:nth-child(1) { animation-delay: 0.05s; }
        .stats-grid .stat-card:nth-child(2) { animation-delay: 0.1s; }
        .stats-grid .stat-card:nth-child(3) { animation-delay: 0.15s; }
        .stats-grid .stat-card:nth-child(4) { animation-delay: 0.2s; }
        .stats-grid .stat-card:nth-child(5) { animation-delay: 0.25s; }
    </style>
</head>
